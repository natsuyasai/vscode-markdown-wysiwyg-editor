{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "types": [
      "vitest/globals"
    ],
    "composite": true,
    "rootDir": "..",
    "outDir": "./dist/test"
  },
  "include": [
    "./vitest.setup.ts",
    "__mocks__/**/*",
    "./src/**/*",
    "../src/message/**/*"
  ],
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx"
  ]
}