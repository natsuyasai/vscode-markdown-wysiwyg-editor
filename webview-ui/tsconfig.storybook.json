{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "types": [
      "node",
      "vite/client"
    ],
    "composite": true,
    "rootDir": "..",
    "outDir": "./dist/storybook"
  },
  "include": [
    ".storybook/**/*",
    "./src/**/*",
    "./scss-modules.d.ts",
    "../src/message/**/*"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx"
  ]
}